<Window x:Class="breakout.StartMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Breakout"
        Height="350" Width="400"
        Background="#0a0a0a"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <TextBlock Text="BREAKOUT"
                   FontSize="32"
                   Foreground="#7eb8f7"
                   FontWeight="Bold"
                   Margin="0,0,0,30"
                   TextAlignment="Center"/>

        <Button Content="Start Game"
                Width="200"
                Height="40"
                Margin="10"
                Click="Start_Click" Background="White" BorderBrush="White" FontFamily="Cascadia Code" FontSize="13"/>

        <Button Content="Leaderboard"
                Width="200"
                Height="40"
                Margin="10"
                Click="Leaderboard_Click" BorderBrush="White" Background="White" FontSize="13" FontFamily="Cascadia Code"/>

    </StackPanel>
</Window>